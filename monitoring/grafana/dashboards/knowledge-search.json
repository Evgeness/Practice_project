{
  "annotations": {"list": []},
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "Search requests (5m)",
      "targets": [
        {"expr": "sum(increase(knowledge_search_requests_total[5m]))", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Average search time",
      "targets": [
        {"expr": "rate(knowledge_search_duration_seconds_sum[5m]) / clamp_min(rate(knowledge_search_duration_seconds_count[5m]), 0.000001)", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 0}
    },
    {
      "type": "piechart",
      "title": "Cache hit / miss",
      "targets": [
        {"expr": "sum by (cache) (increase(knowledge_search_requests_total[15m]))", "legendFormat": "{{cache}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 10, "x": 0, "y": 8}
    }
  ],
  "schemaVersion": 39,
  "tags": ["university", "search"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "title": "University Knowledge Search",
  "uid": "university-knowledge-search",
  "version": 1
}
